{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentCanvas",
  "version": "1.0.0",
  "identifier": "com.agentcanvas.app",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev-server.ps1 4174",
    "devUrl": "http://localhost:4174",
    "frontendDist": "../"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AgentCanvas",
        "width": 1600,
        "height": 980,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
